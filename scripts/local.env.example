# Copy to scripts/local.env (gitignored) and fill in your own paths.
# fetch_models.sh sources it; anything left unset falls back to a neutral
# placeholder and is reported as MISSING rather than silently copying nothing.

# Board-side staging dir for models converted on the x86 host
#BCDL_SRC_DEPLOY=/your/path/to/rdk-deploy/models
#BCDL_SRC_LAS2=/your/path/to/rdk-deploy/las2

# Local rdk_model_zoo checkout (samples/vision)
#BCDL_SRC_ZOO=/your/path/to/rdk_model_zoo/samples/vision

# ssh host of the convert machine, and the models dir of the convert project
# on it (used to self-heal a missing staged model)
#BCDL_CONVERT_HOST=your-convert-host
#BCDL_SRC_BUILD=/your/path/to/convert-project/models
